# ============================================================
# Content Marketing Suite - Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# --- FREE AI APIs ---
# Groq (free tier): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini (free tier): https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# --- OPTIONAL: Publishing Integrations ---
# WordPress REST API (your site)
WORDPRESS_URL=https://yourblog.com
WORDPRESS_USERNAME=your_wp_username
WORDPRESS_APP_PASSWORD=your_wp_app_password

# Buffer (free plan): https://buffer.com
BUFFER_ACCESS_TOKEN=your_buffer_token

# --- APP SETTINGS ---
DEFAULT_TOPIC=AI marketing trends 2025
DEFAULT_TONE=professional
DEFAULT_LANGUAGE=en
MAX_BLOG_WORDS=1500
ENABLE_PLAGIARISM_CHECK=true
ENABLE_SEO_ANALYSIS=true
